# PortCraft Environment Configuration
# Copy to .env and update values before starting

# --- Database ---
POSTGRES_USER=portcraft
POSTGRES_PASSWORD=change_me_to_a_secure_password
POSTGRES_DB=portcraft

# --- Application ---
SECRET_KEY=change_me_to_a_random_string

# --- Network ---
HTTP_PORT=80
HTTPS_PORT=443

# --- Dev only (used by docker-compose.dev.yml) ---
DB_PASSWORD=change_me_to_a_secure_password
